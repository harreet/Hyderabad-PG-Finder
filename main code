async function loadListings(){
  let stored = null;
  try{
    const res = await window.storage.get(STORAGE_KEY);
    stored = res ? JSON.parse(res.value) : null;
  }catch(e){ stored = null; }

  let storedVersion = null;
  try{
    const v = await window.storage.get('seed_version');
    storedVersion = v ? v.value : null;
  }catch(e){ storedVersion = null; }

  if(!stored){
    listings = SEED;
    await saveListings();
    await window.storage.set('seed_version', SEED_VERSION);
  } else if(storedVersion !== SEED_VERSION){
    const userAdded = stored.filter(l => String(l.id).startsWith('u'));
    listings = SEED.concat(userAdded);
    await saveListings();
    await window.storage.set('seed_version', SEED_VERSION);
  } else {
    listings = stored;
  }
  renderAll();
}

async function saveListings(){
  try{ await window.storage.set(STORAGE_KEY, JSON.stringify(listings)); }
  catch(e){ console.error('save failed', e); }
}

function fmtRent(n){ return '₹' + Number(n).toLocaleString('en-IN'); }

function markerColor(type){ return type === 'pg' ? '#ef4444' : '#3b82f6'; }

function pinIconHtml(type){
  const color = markerColor(type);
  const emoji = type === 'flat' ? '💙' : '🌸';
  return `
    <div class="cute-pin">
      <svg width="34" height="46" viewBox="0 0 34 46">
        <path d="M17 0C7.6 0 0 7.6 0 17c0 12 17 29 17 29s17-17 17-29C34 7.6 26.4 0 17 0z"
              fill="${color}" stroke="#fff" stroke-width="2.5"/>
        <circle cx="17" cy="17" r="10" fill="#fff" fill-opacity="0.9"/>
      </svg>
      <span class="pin-emoji">${emoji}</span>
    </div>`;
}

function makeMarker(item){
  const icon = L.divIcon({
    className: '',
    html: pinIconHtml(item.type),
    iconSize: [34, 46],
    iconAnchor: [17, 44],
    popupAnchor: [0, -40]
  });
  const m = L.marker([item.lat, item.lng], { icon }).addTo(map);
  m.bindPopup(popupHtml(item));
  m.on('popupopen', () => bindPopupActions(item.id));
  return m;
}

function popupHtml(item){
  return `
    <div style="min-width:190px">
      <div style="font-weight:700;font-size:13px;margin-bottom:2px;">${escapeHtml(item.name)}</div>
      <div style="font-size:11px;color:#b07f96;margin-bottom:6px;">${escapeHtml(item.area || '')}</div>
      <div style="font-size:15px;font-weight:700;color:${markerColor(item.type)};">${fmtRent(item.rent)}<span style="font-size:11px;color:#b07f96;font-weight:400;">/mo</span></div>
      ${item.notes ? `<div style="font-size:11px;color:#b07f96;margin-top:6px;">${escapeHtml(item.notes)}</div>` : ''}
      ${item.link ? `<div style="margin-top:6px;"><a href="${escapeAttr(item.link)}" target="_blank" style="font-size:11px;color:#ff6fa5;">${item.link.startsWith('tel:') ? 'Call PG owner →' : 'Open listing →'}</a></div>` : ''}
    </div>`;
}

function bindPopupActions(id){}

function escapeHtml(s){ return String(s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function escapeAttr(s){ return escapeHtml(s); }

function passesFilter(item){
  if(item.type === 'flat' && !filters.flat) return false;
  if(item.type === 'pg' && !filters.pg) return false;
  if(item.rent > filters.maxRent) return false;
  return true;
}

function renderAll(){
  Object.values(markers).forEach(m => map.removeLayer(m));
  markers = {};
  const listEl = document.getElementById('list');
  listEl.innerHTML = '';

  const visible = listings.filter(passesFilter);
  if(visible.length === 0){
    listEl.innerHTML = '<div class="empty">No listings match your filters yet.<br>Add one with the button above.</div>';
  }

  visible
    .sort((a,b) => a.rent - b.rent)
    .forEach(item => {
      markers[item.id] = makeMarker(item);

      const card = document.createElement('div');
      card.className = 'card';
      card.innerHTML = `
        <div class="card-top">
          <div class="card-name">${escapeHtml(item.name)}</div>
          <div class="badge ${item.type}">${item.type === 'pg' ? 'PG' : 'FLAT'}</div>
        </div>
        <div class="card-rent" style="color:${markerColor(item.type)}">${fmtRent(item.rent)}<span style="font-size:11px;color:var(--muted);font-weight:400;"> /mo</span></div>
        <div class="card-area">${escapeHtml(item.area || '')}</div>
        ${item.notes ? `<div class="card-notes">${escapeHtml(item.notes)}</div>` : ''}
        <div class="card-actions">
          <button class="del" data-id="${item.id}">Delete</button>
        </div>
      `;
      card.addEventListener('click', (e) => {
        if(e.target.closest('.del')) return;
        map.flyTo([item.lat, item.lng], 15, {duration:0.6});
        markers[item.id].openPopup();
      });
      card.querySelector('.del').addEventListener('click', async (e) => {
        e.stopPropagation();
        listings = listings.filter(l => l.id !== item.id);
        await saveListings();
        renderAll();
      });
      listEl.appendChild(card);
    });
}

// --- Filter controls ---
document.getElementById('toggleFlat').addEventListener('click', (e) => {
  filters.flat = !filters.flat;
  e.target.classList.toggle('active', filters.flat);
  renderAll();
});
document.getElementById('togglePg').addEventListener('click', (e) => {
  filters.pg = !filters.pg;
  e.target.classList.toggle('active', filters.pg);
  renderAll();
});
const rentSlider = document.getElementById('rentSlider');
rentSlider.addEventListener('input', () => {
  filters.maxRent = Number(rentSlider.value);
  document.getElementById('rentVal').textContent = fmtRent(filters.maxRent);
  renderAll();
});

// --- Add listing flow ---
const addBtn = document.getElementById('addBtn');
addBtn.addEventListener('click', () => {
  addMode = !addMode;
  addBtn.classList.toggle('active', addMode);
  addBtn.textContent = addMode ? 'Tap the map to place a pin…' : '+ Add a listing (click map)';
  if(!addMode && tempMarker){ map.removeLayer(tempMarker); tempMarker = null; }
});

map.on('click', (e) => {
  if(!addMode) return;
  if(tempMarker) map.removeLayer(tempMarker);
  const tempIcon = L.divIcon({
    className: '',
    html: `<div class="cute-pin temp-pin">
      <svg width="34" height="46" viewBox="0 0 34 46">
        <path d="M17 0C7.6 0 0 7.6 0 17c0 12 17 29 17 29s17-17 17-29C34 7.6 26.4 0 17 0z"
              fill="#ff6fa5" stroke="#fff" stroke-width="2.5"/>
        <circle cx="17" cy="17" r="10" fill="#fff" fill-opacity="0.9"/>
      </svg>
      <span class="pin-emoji">✨</span>
    </div>`,
    iconSize: [34, 46],
    iconAnchor: [17, 44],
    popupAnchor: [0, -40]
  });
  tempMarker = L.marker(e.latlng, { icon: tempIcon }).addTo(map);
  tempMarker.bindPopup(addFormHtml(e.latlng)).openPopup();
  tempMarker.on('popupclose', () => {
    if(tempMarker){ map.removeLayer(tempMarker); tempMarker = null; }
  });
});

function addFormHtml(latlng){
  const formId = 'newform_' + Date.now();
  setTimeout(() => wireAddForm(formId, latlng), 0);
  return `
    <div class="popup-form" id="${formId}" style="min-width:210px">
      <label>Name / building</label>
      <input type="text" class="f-name" placeholder="e.g. Golf Edge PG">
      <div class="row">
        <div>
          <label>Type</label>
          <select class="f-type">
            <option value="flat">Flat</option>
            <option value="pg">PG</option>
          </select>
        </div>
        <div>
          <label>Rent / mo (₹)</label>
          <input type="number" class="f-rent" placeholder="15000">
        </div>
      </div>
      <label>Area</label>
      <input type="text" class="f-area" placeholder="e.g. Madhapur">
      <label>Notes</label>
      <textarea class="f-notes" placeholder="Sharing type, food, brokerage, contact…"></textarea>
      <label>Listing link (optional)</label>
      <input type="text" class="f-link" placeholder="https://...">
      <button class="popup-save">Save listing</button>
    </div>`;
}

function wireAddForm(formId, latlng){
  const root = document.getElementById(formId);
  if(!root) return;
  root.querySelector('.popup-save').addEventListener('click', async () => {
    const name = root.querySelector('.f-name').value.trim() || 'Untitled listing';
    const type = root.querySelector('.f-type').value;
    const rent = Number(root.querySelector('.f-rent').value) || 0;
    const area = root.querySelector('.f-area').value.trim();
    const notes = root.querySelector('.f-notes').value.trim();
    const link = root.querySelector('.f-link').value.trim();
    const item = {
      id: 'u' + Date.now(),
      type, name, rent, area, notes, link,
      lat: latlng.lat, lng: latlng.lng
    };
    listings.push(item);
    await saveListings();
    if(tempMarker){ map.removeLayer(tempMarker); tempMarker = null; }
    addMode = false;
    addBtn.classList.remove('active');
    addBtn.textContent = '+ Add a listing (click map)';
    renderAll();
  });
}

loadListings();
