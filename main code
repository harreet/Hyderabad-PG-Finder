<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Hyderabad PG + Flat Finder</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.css">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Quicksand:wght@500;600;700&family=Nunito:wght@400;600;700&display=swap');
  :root{
    --bg: #fff5f8;
    --panel: #ffffff;
    --panel-2: #fff0f6;
    --line: #ffd6e7;
    --text: #5a3344;
    --muted: #b07f96;
    --flat: #3b82f6;
    --flat-soft: rgba(59,130,246,0.12);
    --pg: #ef4444;
    --pg-soft: rgba(239,68,68,0.12);
    --accent: #ff6fa5;
    --accent-2: #ffb6d2;
    font-family: 'Nunito', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;height:100%;background:var(--bg);color:var(--text);}
  #app{display:flex;height:100vh;min-height:560px;}

  /* Sidebar */
  #sidebar{
    width:340px;min-width:280px;flex-shrink:0;
    background:var(--panel);
    border-right:1px solid var(--line);
    display:flex;flex-direction:column;
    overflow:hidden;
  }
  .brand{padding:18px 18px 12px;border-bottom:1px solid var(--line);background:linear-gradient(135deg,#fff0f6,#ffffff);}
  .brand h1{font-family:'Quicksand',sans-serif;font-size:18px;margin:0 0 2px;letter-spacing:0.2px;color:var(--accent);}
  .brand p{margin:0;font-size:12px;color:var(--muted);}

  .tile-note{
    margin:10px 14px 0;padding:8px 10px;border-radius:10px;background:var(--panel-2);
    border:1px solid var(--line);font-size:11px;color:var(--muted);line-height:1.4;
  }

  .legend{display:flex;gap:14px;padding:12px 18px;border-bottom:1px solid var(--line);font-size:12px;color:var(--muted);}
  .legend span{display:inline-flex;align-items:center;gap:6px;}
  .dot{width:10px;height:10px;border-radius:50%;display:inline-block;}
  .dot.flat{background:var(--flat);}
  .dot.pg{background:var(--pg);}

  .controls{padding:12px 18px;border-bottom:1px solid var(--line);display:flex;flex-direction:column;gap:10px;}
  .toggle-row{display:flex;gap:8px;}
  .chip{
    flex:1;text-align:center;padding:7px 8px;border-radius:20px;font-size:12px;
    border:1px solid var(--line);cursor:pointer;background:var(--panel-2);color:var(--muted);
    user-select:none;font-weight:600;
  }
  .chip.active.flat{border-color:var(--flat);color:var(--flat);background:var(--flat-soft);}
  .chip.active.pg{border-color:var(--pg);color:var(--pg);background:var(--pg-soft);}

  .rent-row{font-size:12px;color:var(--muted);}
  .rent-row .val{color:var(--accent);font-weight:700;}
  input[type=range]{width:100%;accent-color:var(--accent);margin-top:6px;}

  #addBtn{
    width:100%;padding:9px;border-radius:20px;border:1.5px dashed var(--accent);
    background:#fff;color:var(--accent);font-size:13px;cursor:pointer;font-weight:700;
  }
  #addBtn.active{background:var(--accent);color:#fff;border-style:solid;}

  #list{flex:1;overflow-y:auto;padding:6px 10px 16px;}
  .card{
    background:var(--panel-2);border:1px solid var(--line);border-radius:14px;
    padding:10px 12px;margin:8px 8px;cursor:pointer;transition:border-color .15s, box-shadow .15s;
  }
  .card:hover{border-color:var(--accent-2);box-shadow:0 2px 10px rgba(255,111,165,0.15);}
  .card-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;}
  .card-name{font-size:13px;font-weight:700;line-height:1.3;}
  .badge{font-size:10px;padding:2px 7px;border-radius:20px;font-weight:700;letter-spacing:0.3px;white-space:nowrap;}
  .badge.flat{background:var(--flat-soft);color:var(--flat);}
  .badge.pg{background:var(--pg-soft);color:var(--pg);}
  .card-rent{font-size:14px;font-weight:700;margin-top:4px;}
  .card-area{font-size:11px;color:var(--muted);margin-top:2px;}
  .card-notes{font-size:11px;color:var(--muted);margin-top:6px;line-height:1.4;}
  .card-actions{display:flex;gap:10px;margin-top:8px;}
  .card-actions a, .card-actions button{
    font-size:11px;color:var(--accent);background:none;border:none;cursor:pointer;padding:0;text-decoration:none;
  }
  .card-actions .del{color:#e0668a;}
  .empty{padding:20px;text-align:center;color:var(--muted);font-size:12px;}

  /* Map */
  #map{flex:1;background:#fdeef4;}
  .leaflet-popup-content-wrapper{background:var(--panel);color:var(--text);border-radius:14px;}
  .leaflet-popup-tip{background:var(--panel);}
  .popup-form label{display:block;font-size:11px;color:var(--muted);margin:6px 0 2px;}
  .popup-form input, .popup-form select, .popup-form textarea{
    width:100%;padding:5px 7px;border-radius:8px;border:1px solid var(--line);
    background:var(--panel-2);color:var(--text);font-size:12px;
  }
  .popup-form textarea{resize:vertical;min-height:36px;}
  .popup-form .row{display:flex;gap:8px;}
  .popup-form .row > div{flex:1;}
  .popup-save{
    margin-top:8px;width:100%;padding:6px;border-radius:20px;border:none;
    background:var(--accent);color:#fff;font-weight:700;font-size:12px;cursor:pointer;
  }
  .hint{padding:8px 18px;font-size:11px;color:var(--muted);border-top:1px solid var(--line);background:var(--panel);}

  /* Cute pin markers */
  .cute-pin{position:relative;width:34px;height:46px;display:flex;align-items:flex-start;justify-content:center;filter:drop-shadow(0 2px 3px rgba(0,0,0,0.25));}
  .cute-pin svg{display:block;}
  .cute-pin .pin-emoji{position:absolute;top:6px;left:0;width:34px;text-align:center;font-size:15px;line-height:1;}
  .cute-pin.temp-pin .pin-emoji{font-size:14px;}

  @media (max-width: 760px){
    #app{flex-direction:column;}
    #sidebar{width:100%;height:46%;border-right:none;border-bottom:1px solid var(--line);}
    #map{flex:1;}
  }
</style>
</head>
